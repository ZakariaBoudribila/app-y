# Backend environment variables

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Server
PORT=3001

# JWT (legacy)
# (Optionnel) Compat: utilisé comme fallback si JWT_ACCESS_SECRET est absent.
# Génère un secret fort: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# JWT (access + refresh)
# Génère des secrets différents (64+ chars hex)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
# En local HTTP: false. En prod HTTPS: true.
COOKIE_SECURE=false
# Si front et API sont sur des domaines différents, tu devras souvent passer à 'none'
# (et COOKIE_SECURE=true). En same-site/proxy: 'strict' est OK.
COOKIE_SAME_SITE=strict

# Gemini (Google AI)
# Clé API Google AI Studio
GEMINI_API_KEY=
# Optionnel: modèle (défaut: gemini-1.5-flash)
GEMINI_MODEL=
# Optionnel: fallback si GEMINI_MODEL renvoie 404 / non supporté (défaut: gemini-pro)
GEMINI_FALLBACK_MODEL=
