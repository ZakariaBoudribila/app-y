# Backend environment variables

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Server
PORT=3001

# JWT (legacy)
# (Optionnel) Compat: utilisé comme fallback si JWT_ACCESS_SECRET est absent.
# Génère un secret fort: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# JWT (access + refresh)
# Génère des secrets différents (64+ chars hex)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
# En local HTTP: false. En prod HTTPS: true.
COOKIE_SECURE=false
# Si front et API sont sur des domaines différents, tu devras souvent passer à 'none'
# (et COOKIE_SECURE=true). En same-site/proxy: 'strict' est OK.
COOKIE_SAME_SITE=strict

# Gemini (Google AI)
# Clé API Google AI Studio
GEMINI_API_KEY=
# Optionnel: modèle (défaut: gemini-2.0-flash-lite)
# Valeurs possibles: `gemini-2.0-flash-lite`, `gemini-2.5-flash`, `gemini-pro-latest`, etc.
# Tu peux aussi fournir le nom complet `models/<...>`.
GEMINI_MODEL=
# Optionnel: fallback si GEMINI_MODEL renvoie 404 / non supporté (défaut: gemini-pro-latest)
GEMINI_FALLBACK_MODEL=

# Groq (recommandé si tu veux éviter les quotas Gemini free-tier)
# Clé API Groq (commence souvent par gsk_...)
GROQ_API_KEY=
# Modèle Groq (défaut: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
# Température (défaut: 0.7)
GROQ_TEMPERATURE=0.7

# Anti-spam IA (cooldown par utilisateur, en secondes). Défaut: 3
AI_USER_COOLDOWN_SECONDS=3

# Cache des réponses /ai/support (TTL en secondes). Défaut: 900 (15 minutes)
# Mets 0 pour désactiver.
AI_SUPPORT_CACHE_TTL_SECONDS=900
