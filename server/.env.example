# Backend environment variables

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Server
PORT=3001

# JWT (legacy)
# (Optionnel) Compat: utilisé comme fallback si JWT_ACCESS_SECRET est absent.
# Génère un secret fort: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# JWT (access + refresh)
# Génère des secrets différents (64+ chars hex)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
# En local HTTP: false. En prod HTTPS: true.
COOKIE_SECURE=false
# Si front et API sont sur des domaines différents, tu devras souvent passer à 'none'
# (et COOKIE_SECURE=true). En same-site/proxy: 'strict' est OK.
COOKIE_SAME_SITE=strict

# Groq (provider IA ACTUEL côté backend)
# Clé API Groq (commence souvent par gsk_...)
GROQ_API_KEY=
# Modèle Groq (défaut: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
# Température (défaut: 0.7)
GROQ_TEMPERATURE=0.7

# Gemini (legacy / non utilisé actuellement)
# (Conservé uniquement pour compat / historique. Le backend a été migré vers Groq.)
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_FALLBACK_MODEL=

# Anti-spam IA (cooldown par utilisateur, en secondes). Défaut: 3
# Mets 0 pour désactiver le cooldown après réponse (utile si tu veux enchaîner les messages).
AI_USER_COOLDOWN_SECONDS=10

# Cache des réponses /ai/support (TTL en secondes). Défaut: 900 (15 minutes)
# Mets 0 pour désactiver.
AI_SUPPORT_CACHE_TTL_SECONDS=900
