{
  "version": 2,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "routes": [
    { "src": "/api$", "dest": "/api/[...path].js" },
    { "src": "/api/(.*)", "dest": "/api/[...path].js?path=$1" },
    { "handle": "filesystem" },
    { "src": "/(?!api/)(.*)", "dest": "/index.html" }
  ]
}
